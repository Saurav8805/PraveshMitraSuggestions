# MongoDB Atlas Connection
# Replace with your actual MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appname>

# Gmail SMTP Configuration
# Use your Gmail address and generate an App Password from Google Account settings
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# SMS Service Configuration (Optional - for OTP via SMS)
# Get free API key from: https://www.fast2sms.com/
# Leave empty to use email-only verification
FAST2SMS_API_KEY=your-fast2sms-api-key

# Server Configuration
PORT=3000
NODE_ENV=development

# Optional: Contact Information (shown in emails and footer)
CONTACT_PHONE=+91 9876543210
CONTACT_EMAIL=contact@yourdomain.com
CONTACT_WHATSAPP=https://wa.me/919876543210
